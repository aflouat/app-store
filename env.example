# =============================================================
# .env — Variables d'environnement (NE PAS COMMIT)
# Copier en .env et remplir les valeurs
# =============================================================

# ----- PostgreSQL -----
PG_USER=appstore
PG_PASSWORD=CHANGE_ME_mot_de_passe_fort_ici

# ----- MinIO (stockage S3) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password_fort

# ----- Umami (analytics) -----
UMAMI_SECRET=CHANGE_ME_secret_aleatoire_32_chars

# ----- Netdata monitoring (protection basic auth) -----
MONITOR_USER=admin
# Générer le hash avec : caddy hash-password --plaintext 'votre_mot_de_passe'
MONITOR_HASH=CHANGE_ME_hash_caddy
