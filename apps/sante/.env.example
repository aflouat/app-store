# SantéApp — variables d'environnement requises
# Copier ce fichier en .env.local et remplir les valeurs réelles
# PORT : 3001 (npm run dev lance sur -p 3001)

# PostgreSQL Supabase — schéma sante.* (même instance que marketplace)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true

# NextAuth v5 — JWT signing (OBLIGATOIRE — générer avec : openssl rand -base64 32)
AUTH_SECRET=changeme_32chars_minimum
NEXTAUTH_URL=http://localhost:3001
